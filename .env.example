APP_ENV=development
LOG_LEVEL=INFO

API_PORT=8000
WEB_UI_PORT=8001
BOT_GATEWAY_PORT=8002
INGEST_WORKER_PORT=8003
SCHEDULER_PORT=8004

QDRANT_URL=http://qdrant:6333
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/semantaix
PERSISTENCE_DB_PATH=.data/semantaix_story1.db
TELEGRAM_BOT_TOKEN=replace-me
# Cloud Telegram Bot API by default. To self-host (lifts the 20 MB getFile
# cap to 2 GB), spin up the `telegram_bot_api` service via
# `docker compose --profile local-bot-api up`, fill in TELEGRAM_API_ID and
# TELEGRAM_API_HASH from https://my.telegram.org, set
# TELEGRAM_BOT_API_BASE_URL=http://telegram_bot_api:8081 and
# TELEGRAM_BOT_API_LOCAL_MODE=true, and raise OPERATOR_UPLOAD_MAX_BYTES.
# IMPORTANT one-time migration: run
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/logOut"
# before the first start so the bot is no longer tied to the cloud server.
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_API_LOCAL_MODE=false
TELEGRAM_BOT_API_FILE_STORAGE_ROOT=/var/lib/telegram-bot-api
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_ALERT_USERNAME=@ajdevy
TELEGRAM_ALERT_CHAT_ID=
OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_GROUNDING_MODEL=google/gemini-2.0-flash-lite-001
INCIDENT_DB_PATH=.data/semantaix_incidents.db
INCIDENT_DEDUP_WINDOW_SECONDS=300
TELEGRAM_ALERT_DEBOUNCE_SECONDS=300
HITL_TICKET_DB_PATH=.data/semantaix_hitl.db
HITL_PRIMARY_OPERATOR_USERNAME=@ajdevy
HITL_PRIMARY_OPERATOR_CHAT_ID=
HITL_CONFIG_ADMIN_USERNAME=@ajdevy
INBOUND_ACK_MESSAGE=Минутку, уточню и вернусь с ответом.
BOT_PERSONA_FIRST_NAME=Анна
BOT_PERSONA_LAST_NAME=Иванова
BOT_TELEGRAM_DESCRIPTION=Здравствуйте! Напишите свой вопрос — постараюсь ответить здесь сразу. Если потребуется помощь коллег, передам им и вернусь к вам с ответом.
BOT_TELEGRAM_SHORT_DESCRIPTION=На связи в чате. Пишите ваш вопрос.
API_INTERNAL_BASE_URL=http://api:8000
RAG_GROUNDING_SCORE_THRESHOLD=0.6
DEFAULT_LANGUAGE=ru
DEFAULT_COUNTRY_CODE=RU
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_LOCATION=Moscow
WEATHER_PROVIDER_BASE_URL=https://api.open-meteo.com
RAG_DB_PATH=.data/semantaix_rag.db
KNOWLEDGE_DB_PATH=.data/semantaix_knowledge.db
ANSWER_TRACE_DB_PATH=.data/semantaix_answer_traces.db
ANSWER_TRACE_SNIPPET_MAX_CHARS=240
NL_OPS_ENABLED=true
NL_OPS_DB_PATH=.data/semantaix_nl_ops.db
NL_OPS_ADMIN_USER_IDS=
NL_OPS_DEFAULT_TENANT_ID=default
BACKUP_DB_PATH=.data/semantaix_backups.db
BACKUP_ARCHIVE_DIR=.data/backups
BACKUP_SOURCE_PATHS=.data/semantaix_story1.db,.data/semantaix_incidents.db,.data/semantaix_hitl.db,.data/semantaix_rag.db,.data/semantaix_knowledge.db
OPERATOR_KB_SESSION_TTL_SECONDS=600
# Default = 20 MB (cloud Bot API hard cap on getFile). Raise to 150 MB
# (157286400) when running the local Bot API server.
OPERATOR_UPLOAD_MAX_BYTES=20971520
